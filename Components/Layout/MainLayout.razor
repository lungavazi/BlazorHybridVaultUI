@inherits LayoutComponentBase
@inject LoadingService Loader
@inject AuthService AuthService
@inject NavigationManager Navigation
@implements IDisposable

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@if (!AuthService.IsAuthenticated)
{
    @Body
}
else
{
    <MudLayout>
        @if (Loader.IsLoading)
        {
            <MudOverlay Visible="true" DarkBackground="true">
                <MudProgressCircular Color="Color.Success" Size="Size.Large" Indeterminate="true" />
            </MudOverlay>
        }
        <MudAppBar Color="Color.Tertiary" Fixed="true">
            <MudIconButton Icon="@Icons.Material.Filled.ManageAccounts" OnClick="DrawerToggle" Color="Color.Inherit" />
            <MudSpacer />
            @if (AuthService.IsSubscribed)
            {
                <MudChip T="string" Icon="@Icons.Material.Filled.Subscriptions" Color="Color.Success">
                    Subscribed: @AuthService.SubscribedCycle @if (AuthService.SubscribedAt.HasValue) { <span class="ml-2" style="font-size:0.8rem">since @AuthService.SubscribedAt.Value.ToLocalTime().ToShortDateString()</span> }
                </MudChip>
            }
            else
            {
                <MudChip T="string" Icon="@Icons.Material.Filled.Subscriptions" Color="Color.Warning">Monitoring not activated</MudChip>
            }
            <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit" OnClick="Logout" Title="Sign out" />
        </MudAppBar>
        <MudDrawer @bind-Open="@_drawerOpen" Variant="DrawerVariant.Temporary">
            <Profile />
        </MudDrawer>
        <MudTabs Position="Position.Bottom" Rounded="false" MinimumTabWidth="60px" Elevation="0" PanelClass="pa-0" SliderColor="Color.Tertiary">
            <MudTabPanel Icon="@Icons.Material.Filled.Dashboard" IconColor="Color.Tertiary">
                <Dashboard />
            </MudTabPanel>
            <MudTabPanel Icon="@Icons.Material.Filled.Policy" IconColor="Color.Tertiary">
                <Policies />
            </MudTabPanel>
            <MudTabPanel Icon="@Icons.Material.Filled.AccountBalance" IconColor="Color.Tertiary">
                <Accounts />
            </MudTabPanel>
            <MudTabPanel Icon="@Icons.Material.Filled.People" IconColor="Color.Tertiary">
                <Beneficiaries />
            </MudTabPanel>
            <MudTabPanel Icon="@Icons.Material.Filled.Drafts" IconColor="Color.Tertiary">
                <Wills />
            </MudTabPanel>
            <MudTabPanel Icon="@Icons.Material.Filled.Subscriptions" IconColor="Color.Tertiary">
                <Subscription />
            </MudTabPanel>
        </MudTabs>
    </MudLayout>
}

@code {
    bool _drawerOpen = false;

    private void DrawerToggle(MouseEventArgs args) => _drawerOpen = !_drawerOpen;

    private void Logout()
    {
        AuthService.Logout();
        Navigation.NavigateTo("/login", replace: true);
    }

    protected override void OnInitialized()
    {
        Loader.OnChange += StateHasChanged;
        AuthService.OnAuthStateChanged += StateHasChanged;
        AuthService.OnSubscriptionChanged += StateHasChanged;

        if (!AuthService.IsAuthenticated)
            Navigation.NavigateTo("/login", replace: true);
    }

    public void Dispose()
    {
        Loader.OnChange -= StateHasChanged;
        AuthService.OnAuthStateChanged -= StateHasChanged;
        AuthService.OnSubscriptionChanged -= StateHasChanged;
    }
}
