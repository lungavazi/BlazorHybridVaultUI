@page "/account"
@inject ISnackbar Snackbar
@using MudBlazor
@inject VaultService VaultService
@inject AuthService AuthService
    <EditForm Model="@model" OnValidSubmit="OnValidSubmit">
        <DataAnnotationsValidator />
        <MudGrid>
            <MudItem xs="12">
                <MudCard>
                    <MudCardContent>
                        <MudTextField Label="Account Name" MaxLength="50" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Abc" AdornmentColor="Color.Primary" Immediate="true"
                                      @bind-Value="model.Name" For="@(() => model.Name)" />
                        <MudTextField Label="Account Type" Class="mt-3" MaxLength="50" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Abc" AdornmentColor="Color.Primary" Immediate="true"
                                      @bind-Value="model.AccountType" For="@(() => model.AccountType)" />
                        <MudTextField Label="Account No" Class="mt-3" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Numbers" AdornmentColor="Color.Primary" Immediate="true"
                                      @bind-Value="model.AccountNo" For="@(() => model.AccountNo)" />
                        <MudSelect T="long" MultiSelection="true" Label="Select beneficiary" SelectedValues="model.BeneficiaryIds" 
                                   ToStringFunc="@(new Func<long, string>(GetBeneficiaryName))"
                                   AdornmentIcon="@Icons.Material.Filled.People" AdornmentColor="Color.Primary" Immediate="true" @ref="_beneficiarySelect">
                            @foreach (var beneficiary in beneficiaries)
                            {
                                <MudSelectItem Value="@beneficiary.Id">@beneficiary.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Class="ml-auto">Save</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        </MudGrid>
    </EditForm>
@code {

    [CascadingParameter]
    public IMudDialogInstance? MudDialog { get; set; }

    AccountModel model = new AccountModel();
    [Parameter]
    public AccountDto AccountEditDto { get; set; }

    IEnumerable<BeneficiaryDto> beneficiaries = new List<BeneficiaryDto>();

    private MudSelect<long>? _beneficiarySelect;

    private string GetBeneficiaryName(long id)
    {
        if (id == 0) return "";
        var beneficiary = beneficiaries?.FirstOrDefault(b => b.Id == id);
        return beneficiary?.Name ?? id.ToString();
    }

    protected override async Task OnInitializedAsync()
    {
        beneficiaries = await VaultService.GetBeneficiariesAsync(AuthService.Email ?? string.Empty, null);

        if (AccountEditDto != null)
        {
            model.Id = AccountEditDto.Id;
            model.AccountType = AccountEditDto.AccountType;
            if (AccountEditDto.BeneficiaryIds != null && AccountEditDto.BeneficiaryIds.Count > 0)
            {
                model.BeneficiaryIds = new HashSet<long>(AccountEditDto.BeneficiaryIds);
            }
            model.AccountNo = AccountEditDto.AccountNo;
            model.Name = AccountEditDto.Name;
            model.DateOpened = AccountEditDto.DateOpened;
        }
    }
    private Task OnValidSubmit(EditContext context)
    {
        StateHasChanged();
        return Save();
    }
    async Task Save()
    {
        var selected = _beneficiarySelect?.SelectedValues?
            .Cast<long>()
            .Where(id => id != 0)  // exclude ID 0
            .ToList() ?? new List<long>();

        if (selected.Count == 0)
        {
            Snackbar.Add("Please select at least one beneficiary.", Severity.Warning);
            return;
        }

        if (AccountEditDto != null)
        {
            var accountUpdate = new AccountUpdateDto
            {
                Name = model.Name,
                BeneficiaryIds = selected,
                AccountType = model.AccountType,
                AccountNo = model.AccountNo,
                DateOpened = model.DateOpened
            };
            await VaultService.UpdateAccountAsync(model.Id, accountUpdate);
        }
        else
        {
            var accountDto = new AccountCreateDto
            {
                Name = model.Name,
                UserName = AuthService.Email ?? string.Empty,
                BeneficiaryIds = selected,
                AccountType = model.AccountType,
                AccountNo = model.AccountNo,
                DateOpened = model.DateOpened
            };
            var accoundId = await VaultService.CreateAccountAsync(accountDto);
            model = accoundId > 0 ? model : new AccountModel();
            Snackbar.Add(accoundId > 0 ? "Account created successfully" : "Error occurred.");
        }
        MudDialog?.Close(DialogResult.Ok(new AccountDto { AccountNo = model.AccountNo, AccountType = model.AccountType, DateOpened = model.DateOpened, Id = model.Id, Name = model.Name, BeneficiaryIds=selected}));
    }
}