@page "/policy"
@inject ISnackbar Snackbar
@inject VaultService VaultService
@inject AuthService AuthService

<EditForm Model="@model" OnValidSubmit="OnValidSubmit">
    <DataAnnotationsValidator />
    <MudGrid>
        <MudItem xs="12">
            <MudCard>
                <MudCardContent>
                    <MudTextField Label="Policy Name" MaxLength="50" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Abc" AdornmentColor="Color.Primary" Immediate="true"
                                  @bind-Value="model.Name" For="@(() => model.Name)"  />
                    <MudTextField Label="Policy Type" Class="mt-3" MaxLength="50"
                                  @bind-Value="model.InsuranceType" For="@(() => model.InsuranceType)" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Abc" AdornmentColor="Color.Primary" Immediate="true" />
                    <MudTextField Label="Policy No" Class="mt-3"
                                  @bind-Value="model.InsuranceNo" For="@(() => model.InsuranceNo)" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Numbers" AdornmentColor="Color.Primary" Immediate="true" />
                    <MudTextField T="DateTime" Format="yyyy-MM-dd" Label="Date Opened" InputType="InputType.Date" Value="DateTime.Now"
                                  For="@(() => model.DateOpened)" />
                    <MudSelect T="long" MultiSelection="true" Label="Select beneficiary" SelectedValues="model.BeneficiaryIds" 
                               ToStringFunc="@(new Func<long, string>(GetBeneficiaryName))"
                               AdornmentIcon="@Icons.Material.Filled.People" AdornmentColor="Color.Primary" Immediate="true" @ref="_policyBeneficiarySelect">
                        @foreach (var beneficiary in beneficiaries)
                        {
                            <MudSelectItem Value="@beneficiary.Id">@beneficiary.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudCardContent>
                <MudCardActions>
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Class="ml-auto">Save</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</EditForm>
@code {
    [CascadingParameter]
    public IMudDialogInstance? MudDialog { get; set; }

    [Parameter]
    public PolicyDto PolicyEditDto { get; set; }

    PolicyModel model = new PolicyModel();

    IEnumerable<BeneficiaryDto> beneficiaries = new List<BeneficiaryDto>();

    private MudSelect<long>? _policyBeneficiarySelect;

    private string GetBeneficiaryName(long id)
    {
        if (id == 0) return "";
        var beneficiary = beneficiaries?.FirstOrDefault(b => b.Id == id);
        return beneficiary?.Name ?? id.ToString();
    }

    protected override async Task OnInitializedAsync()
    {
        beneficiaries = await VaultService.GetBeneficiariesAsync(AuthService.Email ?? string.Empty, null);

        if (PolicyEditDto != null)
        {
            model.Id = PolicyEditDto.Id;
            model.Name = PolicyEditDto.Name;
            if (PolicyEditDto.BeneficiaryIds != null && PolicyEditDto.BeneficiaryIds.Count > 0)
            {
                model.BeneficiaryIds = new HashSet<long>(PolicyEditDto.BeneficiaryIds);
            }
            model.DateOpened = PolicyEditDto.DateOpened;
            model.InsuranceType = PolicyEditDto.InsuranceType;
            model.InsuranceNo = PolicyEditDto.InsuranceNo;
        }
    }
    private async Task OnValidSubmit(EditContext context)
    {
        await Save();
    }
    private async Task Save()
    {
        var selected = _policyBeneficiarySelect?.SelectedValues?
            .Cast<long>()
            .Where(id => id != 0)  // exclude ID 0
            .ToList() ?? new List<long>();

        if (selected.Count == 0)
        {
            Snackbar.Add("Please select at least one beneficiary.", Severity.Warning);
            return;
        }

        if (PolicyEditDto != null)
        {
            var policyUpdate = new InsuranceUpdateDto
            {
                BeneficiaryIds = selected,
                Name = model.Name,
                InsuranceType = model.InsuranceType,
                DateOpened = model.DateOpened,
                InsuranceNo = model.InsuranceNo
            };
            await VaultService.UpdateInsuranceAsync(model.Id, policyUpdate);
        }
        else
        {
            var policyDto = new InsuranceCreateDto
            {
                Name = model.Name,
                UserName = AuthService.Email ?? string.Empty,
                BeneficiaryIds = selected,
                InsuranceType = model.InsuranceType,
                InsuranceNo = model.InsuranceNo,
                DateOpened = model.DateOpened
            };

            var insuranceId = await VaultService.CreateInsuranceAsync(policyDto);
            model.Id = insuranceId;
            model = insuranceId > 0 ? model : new PolicyModel();
            Snackbar.Add(insuranceId > 0 ? "Policy created successfully" : "Error occurred.");
        }
        MudDialog?.Close(DialogResult.Ok(new PolicyDto { Id = model.Id, DateOpened = model.DateOpened, InsuranceNo = model.InsuranceNo, InsuranceType = model.InsuranceType, Name = model.Name, BeneficiaryIds = selected }));
    }
}