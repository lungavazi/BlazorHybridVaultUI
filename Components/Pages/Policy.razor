@page "/policy"

<EditForm Model="@model" OnValidSubmit="OnValidSubmit">
    @* <DataAnnotationsValidator /> *@
    <MudGrid>
        <MudItem xs="12">
            <MudCard>
                <MudCardContent>
                    <MudTextField Label="Policy Name" MaxLength="50"
                                  @bind-Value="model.Name" For="@(() => model.Name)" />
                    <MudTextField Label="Policy Type" Class="mt-3" MaxLength="50"
                                  @bind-Value="model.InsuranceType" For="@(() => model.InsuranceType)" />
                    <MudTextField Label="Policy No" Class="mt-3"
                                  @bind-Value="model.InsuranceNo" For="@(() => model.InsuranceNo)" />
                    <MudTextField T="DateTime" Format="yyyy-MM-dd" Label="Date Opened" InputType="InputType.Date"
                                  @bind-Value="model.DateOpened" For="@(() => model.DateOpened)" />
                    <MudSelect T="string" Label="Select beneficiary" @bind-Value="_selectedBeneficiary">
                        <MudSelectItem Value="@("Cappuccino")" />
                        <MudSelectItem Value="@("Cafe Latte")" />
                        <MudSelectItem Value="@("Espresso")" />
                        <MudSelectItem Value="@("Irish Coffee")" />
                    </MudSelect>
                </MudCardContent>
                <MudCardActions>
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Class="ml-auto">Save</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</EditForm>
@code {
    string _selectedBeneficiary;
    PolicyDto model = new PolicyDto();
    bool success;
    private void OnValidSubmit(EditContext context)
    {
        success = true;
        StateHasChanged();
    }
}
