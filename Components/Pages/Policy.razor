@page "/policy"
@inject ISnackbar Snackbar
@inject IHttpClientFactory ClientFactory

<EditForm Model="@model" @ref=editForm OnValidSubmit="OnValidSubmit">
    <DataAnnotationsValidator />
    <MudGrid>
        <MudItem xs="12">
            <MudCard>
                <MudCardContent>
                    <MudTextField Label="Policy Name" MaxLength="50" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Abc" AdornmentColor="Color.Primary" Immediate="true"
                                  @bind-Value="model.Name" For="@(() => model.Name)"  />
                    <MudTextField Label="Policy Type" Class="mt-3" MaxLength="50"
                                  @bind-Value="model.InsuranceType" For="@(() => model.InsuranceType)" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Abc" AdornmentColor="Color.Primary" Immediate="true" />
                    <MudTextField Label="Policy No" Class="mt-3"
                                  @bind-Value="model.InsuranceNo" For="@(() => model.InsuranceNo)" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Numbers" AdornmentColor="Color.Primary" Immediate="true" />
                    <MudTextField T="DateTime" Format="yyyy-MM-dd" Label="Date Opened" InputType="InputType.Date" Value="DateTime.Now"
                                  For="@(() => model.DateOpened)" />
                    <MudSelect T="long" Label="Select beneficiary" @bind-Value="model.BeneficiaryId" For="@(() => model.BeneficiaryId)" AdornmentIcon="@Icons.Material.Filled.People" AdornmentColor="Color.Primary" Immediate="true">
                        @foreach (var beneficiary in beneficiaries)
                        {
                            <MudSelectItem Value="@beneficiary.Id">@beneficiary.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudCardContent>
                <MudCardActions>
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Class="ml-auto">Save</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</EditForm>
@code {
    string _selectedBeneficiary;
    PolicyModel model = new PolicyModel();
    EditForm editForm;
    private class PolicyModel
    {
        [Required]
        public string Name { get; set; }
        [Required]
        public string InsuranceType { get; set; }
        [Required]
        public string InsuranceNo { get; set; }
        [Required]
        public DateTime DateOpened { get; set; }
        [Required]
        [Range(1, int.MaxValue, ErrorMessage = "Please select a beneficiary.")]
        public long BeneficiaryId { get; set; }
    }

    private class InsuranceCreateDto
    {
        public string Name { get; set; }
        public string UserName { get; set; }
        public long BeneficiaryId { get; set; }
        public string InsuranceType { get; set; }
        public string InsuranceNo { get; set; }
        public DateTime DateOpened { get; set; }
    }

    IEnumerable<BeneficiaryDto> beneficiaries = new List<BeneficiaryDto>();

    protected override async Task OnInitializedAsync()
    {
        var httpClient = ClientFactory.CreateClient();
        using var response = await httpClient.GetAsync($"{Constants.API_URL}/beneficiaries/{"lunga@gmail.com"}");
        if (response.IsSuccessStatusCode)
        {
            using var responseStream = await response.Content.ReadAsStreamAsync();
            beneficiaries = await JsonSerializer.DeserializeAsync<IEnumerable<BeneficiaryDto>>(responseStream);
        }
    }
    private Task OnValidSubmit(EditContext context)
    {
        StateHasChanged();
        return Save();
    }
    async Task Save()
    {
        var policyId = await CreatePolicyAsync();
        model = policyId > 0 ? new PolicyModel() : model;
        Snackbar.Add(policyId > 0 ? "Policy created successfully" : "Error occurred.");
    }

    private async Task<int> CreatePolicyAsync()
    {
        try
        {
            var policyDto = new InsuranceCreateDto();
            policyDto.Name = model.Name;
            policyDto.UserName = "lunga@gmail.com";
            policyDto.BeneficiaryId = model.BeneficiaryId;
            policyDto.InsuranceType = model.InsuranceType;
            policyDto.InsuranceNo = model.InsuranceNo;
            policyDto.DateOpened = model.DateOpened;

            var httpClient = ClientFactory.CreateClient();
            using var response = await httpClient.PostAsJsonAsync($"{Constants.API_URL}/insurance/", policyDto);
            var insuranceId = 0;
            if (response.IsSuccessStatusCode)
            {
                using var responseStream = await response.Content.ReadAsStreamAsync();
                insuranceId = await JsonSerializer.DeserializeAsync<int>(responseStream);
            }
            return insuranceId;
        }
        catch (Exception)
        {
            
            throw;
        }
    }
}
