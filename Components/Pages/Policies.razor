@page "/policies"
@using VaultUI.Data.Dto
@inject IHttpClientFactory ClientFactory
@inject IDialogService DialogService

<MudContainer MaxWidth="MaxWidth.Medium">
       <MudPaper Height="650px">
        <MudIconButton Icon="fas fa-plus" Color="Color.Tertiary"
                       Onclick="AddPolicyAsync" />
        <MudText Typo="Typo.h5">Policies</MudText>
            <MudTextField @bind-Value="searchString1"
                          Placeholder="Search All insurance Policies"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium"
                          FullWidth="true"/>
        <MudList T="string">

            @foreach (var policy in policies)
            {
                <MudListItem Text="@policy.Name" SecondaryText="@policy.InsuranceType" Icon="@Icons.Material.Filled.Policy" />
            }
        </MudList>
</MudPaper>
    </MudContainer>

@code {
    public async Task AddPolicyAsync()
    {
        var options = new DialogOptions() { CloseButton = true, FullWidth = true, MaxWidth = MaxWidth.Small, Position = DialogPosition.Center };
        var dialog = await DialogService.ShowAsync<Policy>("Add Policy", options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {

        }
    }
    public IEnumerable<PolicyDto> policies = new List<PolicyDto>();
    protected override async Task OnInitializedAsync()
    {
        try
        {
            await base.OnInitializedAsync();

            using var request = new HttpRequestMessage(HttpMethod.Get, $"{Constants.API_URL}/insurances/{"lunga@gmail.com"}");

            var httpClient = ClientFactory.CreateClient();
            using var response = await httpClient.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                using var responseStream = await response.Content.ReadAsStreamAsync();
                policies = await JsonSerializer.DeserializeAsync<IEnumerable<PolicyDto>>(responseStream);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
            policies = new List<PolicyDto>();
            // throw;
        }

    }
    string searchString1 = "";
}
