@page "/beneficiary"
@inject ISnackbar Snackbar
@inject VaultService VaultService

<EditForm Model="@model" OnValidSubmit="OnValidSubmit">
    <DataAnnotationsValidator />
    <MudGrid>
        <MudItem xs="12">
            <MudCard>
                <MudCardContent>
                    <MudTextField Label="Full Name" MaxLength="50" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Abc" AdornmentColor="Color.Primary" Immediate="true"
                                  @bind-Value="model.Name" For="@(() => model.Name)" />
                    <MudTextField Label="Relationship" Class="mt-3" MaxLength="50" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.People" AdornmentColor="Color.Primary" Immediate="true"
                                  @bind-Value="model.Relationship" For="@(() => model.Relationship)" />
                    <MudTextField Label="CellNo" Class="mt-3" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Rounded.ContactPhone" AdornmentColor="Color.Primary" Immediate="true"
                                  @bind-Value="model.CellPhone" For="@(() => model.CellPhone)" />
                    <MudTextField Label="Email" Class="mt-3" MaxLength="50" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Rounded.Email" AdornmentColor="Color.Primary" Immediate="true"
                                  @bind-Value="model.Email" For="@(() => model.Email)" />
                    <MudTextField Label="Physical Address" Class="mt-3" Lines="5" MaxLength="100" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Rounded.Home" AdornmentColor="Color.Primary" Immediate="true"
                                  @bind-Value="model.Address" For="@(() => model.Address)" />
                    <MudTextField T="DateTime" Format="yyyy-MM-dd" Label="Date Of Birth" InputType="InputType.Date" AdornmentIcon="@Icons.Material.Filled.DateRange" AdornmentColor="Color.Primary"
                                  @bind-Value="model.DateOfBirth" For="@(() => model.DateOfBirth)" />
                </MudCardContent>
                <MudCardActions>
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Class="ml-auto">Save</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</EditForm>
@code {

    [CascadingParameter]
    public IMudDialogInstance? MudDialog { get; set; }

    [Parameter]
    public BeneficiaryDto? BeneficiaryEditDto { get; set; }
    BeneficiaryModel model = new BeneficiaryModel();

    private Task OnValidSubmit(EditContext context)
    {
        return Save();
    }
    private async Task Save()
    {
        if (BeneficiaryEditDto != null)
        {
            var beneficiaryUpdate = new BeneficiaryUpdateDto { Name = model.Name, Relationship = model.Relationship, CellNo = model.CellPhone, Email = model.Email, Address = model.Address, DateOfBirth = model.Address };
            await VaultService.UpdateBeneficiaryAsync(model.Id, beneficiaryUpdate);
        }
        else
        {
            var beneficiaryID = await CreateBeneficiaryAsync();
            model = beneficiaryID > 0 ? model : new BeneficiaryModel();
            model.Id = beneficiaryID;
            Snackbar.Add(beneficiaryID > 0 ? "Beneficiary created successfully" : "Error occurred.");
        }
        MudDialog?.Close(DialogResult.Ok(new BeneficiaryDto { Address = model.Address, DateOfBirth = model.DateOfBirth.ToShortDateString(), CellNo = model.CellPhone, Email = model.Email, Id = model.Id, Name = model.Name, Relationship = model.Relationship, SecondaryEmail = model.Email, SecondaryTelephone = model.CellPhone }));
    }
    protected override async Task OnInitializedAsync()
    {
        if (BeneficiaryEditDto != null)
        {
            model.Address = BeneficiaryEditDto.Address;
            model.Name = BeneficiaryEditDto.Name;
            model.UserId = BeneficiaryEditDto.UserId;
            model.Relationship = BeneficiaryEditDto.Relationship;
            model.CellPhone = BeneficiaryEditDto.CellNo;
            // model.DateOfBirth = BeneficiaryEditDto.DateOfBirth;
            model.Email = BeneficiaryEditDto.Email;
            model.Id = BeneficiaryEditDto.Id;
        }
    }
    private async Task<long> CreateBeneficiaryAsync()
    {
        try
        {
            var beneficiaryCreateDto = new BeneficiaryCreateDto();
            beneficiaryCreateDto.Name = model.Name;
            beneficiaryCreateDto.UserName = "lunga@gmail.com";
            beneficiaryCreateDto.Relationship = model.Relationship;
            beneficiaryCreateDto.CellNo = model.CellPhone;
            beneficiaryCreateDto.SecondaryTelephone = model.CellPhone;
            beneficiaryCreateDto.Email = model.Email;
            beneficiaryCreateDto.secondaryEmail = model.Email;
            beneficiaryCreateDto.Address = model.Address;
            beneficiaryCreateDto.DateOfBirth = model.DateOfBirth.ToShortDateString();

            var beneficiaryID = await VaultService.CreateBeneficiaryAsync(beneficiaryCreateDto);
            return beneficiaryID;
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.InnerException);
            throw;
        }
    }
}
