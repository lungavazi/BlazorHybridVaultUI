@page "/accounts"
@inject IDialogService DialogService
@inject VaultService VaultService
@inject LoadingService Loader
<div class="dashboard-scroll-container">
<MudContainer MaxWidth="MaxWidth.Medium">
    <MudPaper>
        <MudIconButton Icon="fas fa-plus" Color="Color.Tertiary" OnClick="AddAccountAsync" />
            <MudText Typo="Typo.h5">Accounts</MudText>
            <MudTextField @bind-Value="searchString"
                          Placeholder="Search All Accounts"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium"
                          FullWidth="true"
                          @onkeydown="HandleKeyDown"/>
        <MudList T="string">

            @foreach (var account in AccountsDto)
            {
                    <MudListItem Text="@account.Name" SecondaryText="@account.AccountType" Icon="@Icons.Material.Filled.AccountBalance" OnClick="@(() => EditAccount(account))">
                    <MudHighlighter Text="@account.Name" HighlightedText="@searchString"></MudHighlighter>
                        <MudMenu Icon="@Icons.Material.Filled.Settings"
                                 Color="Color.Tertiary">
                            <MudMenuItem Label="Remove" Icon="@Icons.Material.Filled.Delete" OnClick="@(() => DeleteAccountAsync(account.Id))" />
                        </MudMenu>
                </MudListItem>
            }
        </MudList>
        </MudPaper>
    </MudContainer>
    </div>
@code {
    string searchString;
    public async Task EditAccount(AccountDto account)
    {
        var parameters = new DialogParameters
        {
            ["AccountEditDto"] = account
        };

        var options = new DialogOptions() { CloseButton = true, FullWidth = true, MaxWidth = MaxWidth.Small, Position = DialogPosition.Center };
        var dialog = await DialogService.ShowAsync<Account>("Edit Account", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            // if (result.Data is AccountModel data)
            // if (data != null)
            // var accountToUpdate = AccountsDto.FirstOrDefault(x => x.Id == data.Id);

        }

    }
    public async Task DeleteAccountAsync(long Id)
    {
        await VaultService.DeleteAccountAsync(Id);
    }
    public async Task AddAccountAsync()
    {
        var options = new DialogOptions() { CloseButton = true, FullWidth = true, MaxWidth = MaxWidth.Small, Position = DialogPosition.Center };
        var dialog = await DialogService.ShowAsync<Account>("Add Account", options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            if (result.Data is AccountDto data)
                if (data != null)
                    AccountsDto.Select(x => x.Id == data.Id);

        }
    }
    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await RefreshAccounts();
        }
    }
    protected override async Task OnInitializedAsync()
    {
        try
        {
            // await base.OnInitializedAsync();
            Loader.IsLoading = true;
            await RefreshAccounts();

            Loader.IsLoading = false;
        }
        catch (Exception ex)
        {
            Loader.IsLoading = false;
            // throw;
        }
    }

    private async Task RefreshAccounts()
    {
        AccountsDto = await VaultService.GetAccoutsAsync("lunga@gmail.com", searchString);
    }
    private IEnumerable<AccountDto> AccountsDto = new List<AccountDto>();
}
