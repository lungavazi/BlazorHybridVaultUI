@page "/accounts"
@using VaultUI.Data.Dto
@inject IHttpClientFactory ClientFactory
@inject IDialogService DialogService

<MudContainer MaxWidth="MaxWidth.Medium">
    <MudPaper Height="650px">
        <MudIconButton Icon="fas fa-plus" Color="Color.Tertiary" OnClick="AddAccountAsync" />
            <MudText Typo="Typo.h5">Accounts</MudText>
            <MudTextField @bind-Value="searchString"
                          Placeholder="Search All Accounts"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium"
                          FullWidth="true"
                          @onkeydown="HandleKeyDown"/>
        <MudList T="string">

            @foreach (var account in AccountsDto)
            {
                <MudListItem Text="@account.Name" SecondaryText="@account.AccountType" Icon="@Icons.Material.Filled.CommentBank" />
            }
        </MudList>
        </MudPaper>
    </MudContainer>

@code {
    string searchString;

    public async Task AddAccountAsync()
    {
        var options = new DialogOptions() { CloseButton = true, FullWidth = true, MaxWidth = MaxWidth.Small, Position = DialogPosition.Center };
        var dialog = await DialogService.ShowAsync<Account>("Add Account", options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {

        }
    }
    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
             OnInitializedAsync();
        }
    }
    protected override async Task OnInitializedAsync()
    {
        try
        {
            await base.OnInitializedAsync();

            using var request = new HttpRequestMessage(HttpMethod.Get, $"{Constants.API_URL}/accounts/{"lunga@gmail.com"}?accountName={searchString}");

            var httpClient = ClientFactory.CreateClient();
            using var response = await httpClient.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                using var responseStream = await response.Content.ReadAsStreamAsync();
                AccountsDto = await JsonSerializer.DeserializeAsync<IEnumerable<AccountDto>>(responseStream);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
            // throw;
        }

    }
    private IEnumerable<AccountDto> AccountsDto = new List<AccountDto>();
}
