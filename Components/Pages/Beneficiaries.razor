@page "/beneficiaries"
@using VaultUI.Data.Dto
@inject IDialogService DialogService
@inject IHttpClientFactory ClientFactory
<MudContainer MaxWidth="MaxWidth.Medium">
    <MudPaper Height="650px">
        <MudIconButton Icon="fas fa-plus" Color="Color.Tertiary" OnClick="AddBeneficiaryAsync"/>
            <MudText Typo="Typo.h5">Beneficiaries</MudText>
        <MudTextField @bind-Value="searchString"
                          Placeholder="Search All Beneficiaries..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium"
                          FullWidth="true"
                          @onkeydown="HandleKeyDown" />
        <MudList T="BeneficiaryDto">
            @foreach (var beneficiary in BeneficiariesDto)
        {
                <MudListItem Text="@beneficiary.Name" SecondaryText="@beneficiary.Relationship" Icon="@Icons.Material.Filled.People"/>
        }
    </MudList>
    </MudPaper>
    </MudContainer>
@code {

    // public EventCallback ViewBeneficiareyAsync;
    string searchString = "";
    public IEnumerable<BeneficiaryDto> BeneficiariesDto = new List<BeneficiaryDto>();
    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            OnInitializedAsync();
        }
    }

    public async Task AddBeneficiaryAsync()
    {
        var options = new DialogOptions() { CloseButton = true,FullWidth=true, MaxWidth = MaxWidth.Small, Position=DialogPosition.Center };
        var dialog = await DialogService.ShowAsync<Beneficiary>("Add Beneficiary", options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await base.OnInitializedAsync();

            using var request = new HttpRequestMessage(HttpMethod.Get, $"{Constants.API_URL}/beneficiaries/{"lunga@gmail.com"}?beneficiaryName={searchString}");

            var httpClient = ClientFactory.CreateClient();
            using var response = await httpClient.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                using var responseStream = await response.Content.ReadAsStreamAsync();
                BeneficiariesDto = await JsonSerializer.DeserializeAsync<IEnumerable<BeneficiaryDto>>(responseStream);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
            // throw;
        }
    }

}